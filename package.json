{
  "name": "transit-first-rental-app",
  "private": true,
  "version": "0.0.1",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "docker-compose up -d && concurrently \"npm:dev:api\" \"npm:dev:web\" \"npm:dev:worker\"",
    "dev:api": "npm --workspace apps/api run start:dev",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:worker": "npm --workspace apps/worker run start:dev",
    "db:migrate": "npm --workspace packages/db run migrate",
    "db:seed": "npm --workspace packages/db run seed",
    "test": "npm --workspaces --if-present run test",
    "lint": "npm --workspaces --if-present run lint",
    "typecheck": "npm --workspaces --if-present run typecheck",
    "generate:openapi": "npm --workspace apps/api run generate:openapi"
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  }
}
